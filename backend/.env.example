# Server
PORT=3001
NODE_ENV=development

# MySQL Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=wardity
# Cloud MySQL (e.g. Aiven) — set DB_SSL=true
# DB_SSL=true

# Seed: npm run seed:catalog keeps users; npm run seed wipes everything (dev).
# SEED_MODE=catalog

# JWT (REQUIRED in production)
JWT_SECRET=your-secure-jwt-secret-here
JWT_EXPIRES_IN=7d

# CORS (REQUIRED in production — your frontend URL)
CORS_ORIGIN=http://localhost:5173

# SMTP (Email Notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=orders@wardity.com

# Notifications
OWNER_EMAIL=abdalrahmanamr275@gmail.com
WHATSAPP_PHONE=201115239553
